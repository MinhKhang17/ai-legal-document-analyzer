# Spring Boot
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# PostgreSQL (local development values; Docker Compose overrides DB_URL)
DB_URL=jdbc:postgresql://localhost:5432/ai_legal_db
DB_USERNAME=postgres
DB_PASSWORD=12345

# Internal services and storage
APP_API_CALLBACK_BASE_URL=http://localhost:8080
APP_AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_CONNECT_TIMEOUT=5s
AI_SERVICE_READ_TIMEOUT=130s
APP_STORAGE_UPLOAD_ROOT=uploads
FRONTEND_BASE_URL=http://localhost:5173
TICKET_ATTACHMENT_MAX_SIZE_KB=500
TICKET_ATTACHMENT_MAX_PER_MESSAGE=5
TICKET_ATTACHMENT_MAX_PER_TICKET=30
TICKET_ATTACHMENT_UPLOAD_ROOT=uploads/ticket_attachments

# JWT - replace before deploying outside local development
JWT_SECRET=replace-with-a-secret-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
JWT_REFRESH_COOKIE_NAME=refreshToken

# SMTP / mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_ENABLED=false

# VNPAY sandbox - replace credentials outside local development
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/v1/payment-transactions/vnpay-return
VNPAY_TMN_CODE=replace_with_vnpay_tmn_code
VNPAY_HASH_SECRET=replace_with_vnpay_hash_secret
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_CURR_CODE=VND
VNPAY_ORDER_TYPE=other
VNPAY_LOCALE=vn
