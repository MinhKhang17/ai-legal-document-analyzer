VITE_APP_NAME=LexiGuard AI Legal Suite
VITE_DEFAULT_LANGUAGE=vi
VITE_DEFAULT_THEME=system

# Local browser default. Docker builds can override this with FRONTEND_API_BASE_URL.
VITE_API_BASE_URL=http://localhost:8080
VITE_AI_SERVICE_BASE_URL=http://localhost:8000

# Auth
VITE_AUTH_REGISTER_API=/api/v1/auth/register
VITE_AUTH_LOGIN_API=/api/v1/auth/login
VITE_AUTH_REFRESH_API=/api/v1/auth/refresh
VITE_AUTH_ME_API=/api/v1/auth/me
VITE_AUTH_LOGOUT_API=/api/v1/auth/logout
VITE_AUTH_VERIFY_EMAIL_API=/api/v1/auth/verify-email
VITE_AUTH_RESEND_VERIFICATION_API=/api/v1/auth/resend-verification
VITE_AUTH_FORGOT_PASSWORD_API=/api/v1/auth/forgot-password
VITE_AUTH_RESET_PASSWORD_API=/api/v1/auth/reset-password

# Workspaces
VITE_WORKSPACES_API=/api/v1/workspaces
VITE_WORKSPACE_DETAIL_API=/api/v1/workspaces/:workspaceId
VITE_WORKSPACE_DOCUMENTS_API=/api/v1/workspaces/:workspaceId/documents

# Chat
VITE_WORKSPACE_CHAT_SESSIONS_API=/api/v1/workspaces/:workspaceId/chat-sessions
VITE_WORKSPACE_MESSAGES_API=/api/v1/workspaces/:workspaceId/messages
VITE_CHAT_SESSIONS_API=/api/v1/chat-sessions
VITE_CHAT_SESSION_DETAIL_API=/api/v1/chat-sessions/:chatSessionId
VITE_CHAT_SESSION_MESSAGES_API=/api/v1/chat-sessions/:chatSessionId/messages
VITE_CHAT_MESSAGES_API=/api/v1/chat-messages
VITE_CHAT_MESSAGE_DETAIL_API=/api/v1/chat-messages/:messageId
VITE_CHAT_SESSION_SUMMARY_API=/api/v1/chat-sessions/:chatSessionId/summary
VITE_CHAT_SESSION_MEMORY_API=/api/v1/chat-sessions/:chatSessionId/memory
VITE_CHAT_MESSAGE_FEEDBACK_API=/api/v1/chat-messages/:messageId/feedback
VITE_CHAT_SESSION_SHARE_API=/api/v1/chat-sessions/:chatSessionId/share
VITE_CHAT_SESSION_MARKDOWN_EXPORT_API=/api/v1/chat-sessions/:chatSessionId/export/markdown
VITE_SHARED_CHAT_API=/api/v1/shared/chat/:shareToken

# Subscriptions
VITE_SUBSCRIPTION_PLANS_API=/api/v1/subscriptions/plans
VITE_SUBSCRIPTION_PLAN_DETAIL_API=/api/v1/subscriptions/plans/:planId
VITE_SUBSCRIPTION_SUBSCRIBE_API=/api/v1/subscriptions/subscribe
VITE_SUBSCRIPTION_MY_PLAN_API=/api/v1/subscriptions/my-plan
VITE_SUBSCRIPTION_MY_PLAN_CANCEL_API=/api/v1/subscriptions/my-plan/:customerPlanId/cancel
VITE_SUBSCRIPTION_MY_USAGE_API=/api/v1/subscriptions/my-usage
VITE_SUBSCRIPTION_REFUNDS_API=/api/v1/subscriptions/refunds
VITE_SUBSCRIPTION_MY_REFUNDS_API=/api/v1/subscriptions/refunds/me
VITE_SUBSCRIPTION_REFUND_DETAIL_API=/api/v1/subscriptions/refunds/:refundId
VITE_ADMIN_REFUND_STATUS_API=/api/v1/subscriptions/refunds/:refundId/status

# Payment
VITE_PAYMENT_TRANSACTIONS_API=/api/v1/payment-transactions
VITE_PAYMENT_TRANSACTIONS_ME_API=/api/v1/payment-transactions/me
VITE_PAYMENT_TRANSACTION_VNPAY_URL_API=/api/v1/payment-transactions/:transactionId/vnpay-url

# Users
VITE_USERS_API=/api/v1/users
VITE_USER_DETAIL_API=/api/v1/users/:userId
VITE_CHANGE_PASSWORD_API=/api/v1/users/change-password
VITE_ADMIN_EXPERTS_API=/api/v1/admin/users/experts
VITE_ADMIN_EXPERT_RESEND_API=/api/v1/admin/users/experts/resend-activation

# Legal tickets - customer
VITE_LEGAL_TICKETS_API=/api/v1/legal-tickets
VITE_LEGAL_TICKETS_MY_API=/api/v1/legal-tickets/my
VITE_LEGAL_TICKET_DETAIL_API=/api/v1/legal-tickets/:ticketId
VITE_LEGAL_TICKET_MESSAGES_API=/api/v1/legal-tickets/:ticketId/messages
VITE_LEGAL_TICKET_FILES_API=/api/v1/legal-tickets/:ticketId/files
VITE_LEGAL_TICKET_FILE_DOWNLOAD_API=/api/v1/legal-tickets/:ticketId/files/:documentId/download
VITE_LEGAL_TICKET_CANCEL_API=/api/v1/legal-tickets/:ticketId/cancel
VITE_LEGAL_TICKET_CUSTOMER_REPLY_API=/api/v1/legal-tickets/:ticketId/customer-reply
VITE_LEGAL_TICKET_CLOSE_API=/api/v1/legal-tickets/:ticketId/close
VITE_LEGAL_TICKET_REOPEN_API=/api/v1/legal-tickets/:ticketId/reopen

# Legal tickets - admin
VITE_ADMIN_TICKETS_API=/api/v1/admin/tickets
VITE_ADMIN_TICKET_DETAIL_API=/api/v1/admin/tickets/:ticketId
VITE_ADMIN_TICKET_SUMMARY_API=/api/v1/admin/tickets/:ticketId/summary
VITE_ADMIN_TICKET_CHAT_HISTORY_API=/api/v1/admin/tickets/:ticketId/chat-history
VITE_ADMIN_TICKET_FILES_API=/api/v1/admin/tickets/:ticketId/files
VITE_ADMIN_TICKET_ASSIGN_LAWYER_API=/api/v1/admin/tickets/:ticketId/assign-lawyer
VITE_ADMIN_TICKET_REASSIGN_LAWYER_API=/api/v1/admin/tickets/:ticketId/reassign-lawyer
VITE_ADMIN_TICKET_REJECT_API=/api/v1/admin/tickets/:ticketId/reject
VITE_ADMIN_DOCUMENT_DOWNLOAD_API=/api/v1/admin/documents/:documentId/download

# Legal tickets - lawyer
VITE_LAWYER_TICKETS_API=/api/v1/lawyer/tickets
VITE_LAWYER_TICKETS_MY_API=/api/v1/lawyer/tickets/my
VITE_LAWYER_TICKET_DETAIL_API=/api/v1/lawyer/tickets/:ticketId
VITE_LAWYER_TICKET_MESSAGES_API=/api/v1/lawyer/tickets/:ticketId/messages
VITE_LAWYER_TICKET_FILES_API=/api/v1/lawyer/tickets/:ticketId/files
VITE_LAWYER_TICKET_CLOSE_API=/api/v1/lawyer/tickets/:ticketId/close
VITE_LAWYER_TICKET_DOWNLOAD_API=/api/v1/lawyer/tickets/:ticketId/download/:documentId

# Backend AI features
VITE_AI_TICKET_ASSESSMENT_API=/api/v1/ai/tickets/:ticketId/assessment
VITE_AI_TICKET_SUMMARY_API=/api/v1/ai/tickets/:ticketId/summary
VITE_AI_TICKET_CITATIONS_API=/api/v1/ai/tickets/:ticketId/citations
VITE_AI_CHAT_CITATIONS_API=/api/v1/ai/chats/:chatMessageId/citations

# Backend Knowledge Base
VITE_ADMIN_KNOWLEDGE_BASE_API=/api/v1/admin/knowledge-base
VITE_ADMIN_KNOWLEDGE_BASE_UPLOAD_API=/api/v1/admin/knowledge-base/upload
VITE_ADMIN_KNOWLEDGE_BASE_DETAIL_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId
VITE_ADMIN_KNOWLEDGE_BASE_VERSIONS_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId/versions
VITE_ADMIN_KNOWLEDGE_BASE_INGEST_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId/ingest
VITE_ADMIN_KNOWLEDGE_BASE_INGESTION_JOB_API=/api/v1/admin/knowledge-base/ingestion-jobs/:jobId
VITE_ADMIN_KNOWLEDGE_BASE_FAIL_JOB_API=/api/v1/admin/knowledge-base/ingestion-jobs/:jobId/failed
# Optional override; the frontend uses this path by default.
VITE_ADMIN_KNOWLEDGE_BASE_INGESTED_DOCUMENTS_API=/api/v1/admin/knowledge-bases/:knowledgeBaseEntryId/ingested-documents
VITE_ADMIN_KNOWLEDGE_BASE_REVIEW_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId/review
VITE_ADMIN_KNOWLEDGE_BASE_PUBLISH_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId/publish
VITE_ADMIN_KNOWLEDGE_BASE_UNPUBLISH_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId/unpublish
VITE_ADMIN_KNOWLEDGE_BASE_ARCHIVE_API=/api/v1/admin/knowledge-base/:knowledgeBaseEntryId/archive
# Backend Contracts
VITE_CONTRACT_GENERATE_API=/api/v1/contracts/generate
VITE_CONTRACTS_API=/api/v1/contracts
VITE_MY_CONTRACTS_API=/api/v1/contracts/my
VITE_CONTRACT_DETAIL_API=/api/v1/contracts/:contractId
VITE_CONTRACT_VERSIONS_API=/api/v1/contracts/:contractId/versions
VITE_CONTRACT_REVERT_VERSION_API=/api/v1/contracts/:contractId/versions/:versionNo/revert

# Feedback
VITE_ADMIN_FEEDBACK_SURVEYS_API=/api/v1/admin/feedback/surveys
VITE_ADMIN_FEEDBACK_SURVEY_DETAIL_API=/api/v1/admin/feedback/surveys/:surveyId
VITE_FEEDBACK_SURVEY_RESPONSES_API=/api/v1/feedback/surveys/:surveyId/responses
VITE_FEEDBACK_AI_REPORTS_API=/api/v1/feedback/ai-reports
VITE_ADMIN_FEEDBACK_AI_REPORTS_API=/api/v1/admin/feedback/ai-reports
VITE_ADMIN_FEEDBACK_AI_REPORT_DETAIL_API=/api/v1/admin/feedback/ai-reports/:reportId
VITE_ADMIN_CHAT_FEEDBACK_API=/api/v1/admin/chat-messages/feedback

# AI-service system
VITE_AI_ROOT_API=/
VITE_AI_HEALTH_API=/health
VITE_AI_TECHNOLOGIES_API=/technologies

# AI-service risk knowledge
VITE_AI_RISK_KNOWLEDGE_SUPPORTED_FORMATS_API=/admin/risk-knowledge/supported-formats
VITE_AI_RISK_KNOWLEDGE_IMPORT_API=/admin/risk-knowledge/import
VITE_AI_RISK_KNOWLEDGE_IMPORT_V2_API=/admin/risk-knowledge/import-v2
VITE_AI_RISK_KNOWLEDGE_QUERY_API=/admin/risk-knowledge/query
VITE_AI_RISK_KNOWLEDGE_QUERY_V2_API=/admin/risk-knowledge/query-v2

# AI-service contracts
VITE_AI_CONTRACTS_SUPPORTED_FORMATS_API=/v2/contracts/supported-formats
VITE_AI_CONTRACTS_UPLOAD_API=/v2/contracts/upload
