FROM node:22-alpine AS build
WORKDIR /app
ARG VITE_API_BASE_URL
ARG VITE_AUTH_REGISTER_API
ARG VITE_AUTH_LOGIN_API
ARG VITE_AUTH_REFRESH_API
ARG VITE_AUTH_ME_API
ARG VITE_WORKSPACE_CREATE_API
ARG VITE_WORKSPACE_DOCUMENTS_API
ARG VITE_WORKSPACE_LIST_API
ARG VITE_WORKSPACE_DETAIL_API
ARG VITE_SUBSCRIPTION_PLANS_API
ARG VITE_CUSTOMER_PLAN_SUBSCRIBE_API
ARG VITE_CUSTOMER_PLAN_ME_API
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_AUTH_REGISTER_API=$VITE_AUTH_REGISTER_API
ENV VITE_AUTH_LOGIN_API=$VITE_AUTH_LOGIN_API
ENV VITE_AUTH_REFRESH_API=$VITE_AUTH_REFRESH_API
ENV VITE_AUTH_ME_API=$VITE_AUTH_ME_API
ENV VITE_WORKSPACE_CREATE_API=$VITE_WORKSPACE_CREATE_API
ENV VITE_WORKSPACE_DOCUMENTS_API=$VITE_WORKSPACE_DOCUMENTS_API
ENV VITE_WORKSPACE_LIST_API=$VITE_WORKSPACE_LIST_API
ENV VITE_WORKSPACE_DETAIL_API=$VITE_WORKSPACE_DETAIL_API
ENV VITE_SUBSCRIPTION_PLANS_API=$VITE_SUBSCRIPTION_PLANS_API
ENV VITE_CUSTOMER_PLAN_SUBSCRIBE_API=$VITE_CUSTOMER_PLAN_SUBSCRIBE_API
ENV VITE_CUSTOMER_PLAN_ME_API=$VITE_CUSTOMER_PLAN_ME_API
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
