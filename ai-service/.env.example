# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_MAX_QUERY_LIMIT=500

# --- LLM provider: NONE | GEMINI | OLLAMA | VLLM ---
LLM_PROVIDER=NONE
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8001
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# --- Embeddings (RAG semantic search) ---
# AUTO: use Gemini embeddings when LLM_API_KEY is set, else lexical fallback.
EMBEDDING_PROVIDER=AUTO
EMBEDDING_MODEL=gemini-embedding-001

# --- Security (optional internal key for /graph/query and /graph/seed) ---
AI_SERVICE_API_KEY=

# --- CORS (comma-separated) ---
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:5173

# --- API path prefix applied to every router (gateway-friendly) ---
# All endpoints are served under this prefix, e.g. /api/ai/health.
# Set to empty to serve at root.
API_PREFIX=/api/ai
