NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

VECTOR_INDEX_NAME=chunk_embedding_index
LEGAL_VECTOR_INDEX_NAME=legal_chunk_embedding_index

EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL_NAME=hashing-legal-v1

LLM_PROVIDER=gemini
LLM_V2_ENABLED=false
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FALLBACK_MODEL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TIMEOUT_SECONDS=120
GEMINI_MAX_OUTPUT_TOKENS=128
GEMINI_MAX_RETRIES=4
GEMINI_RETRY_BACKOFF_SECONDS=2
LLM_V2_MAX_CONCURRENCY=4

CHUNK_TARGET_MIN_TOKENS=400
CHUNK_TARGET_MAX_TOKENS=600
CHUNK_HARD_MAX_TOKENS=800
CHUNK_V2_TARGET_MIN_TOKENS=120
CHUNK_V2_TARGET_MAX_TOKENS=220
CHUNK_V2_HARD_MAX_TOKENS=320
