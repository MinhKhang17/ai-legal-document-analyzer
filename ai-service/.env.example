NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

VECTOR_INDEX_NAME=chunk_embedding_index
LEGAL_VECTOR_INDEX_NAME=legal_chunk_embedding_index
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_DIMENSIONS=384
DOCUMENT_IMPORT_DIR=/app/uploads

LLM_PROVIDER=gemini
LLM_V2_ENABLED=false
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_API_KEY=your_gemini_api_key_here
API_HOST=0.0.0.0
API_PORT=8000

# ── Nâng cấp AI (v2) ──────────────────────────────────────────

# Gemini Embedding API Fallback (Tier 2 fallback khi SentenceTransformer lỗi)
# Model: text-embedding-004 (768d native, truncated to GEMINI_EMBEDDING_DIMENSIONS)
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_EMBEDDING_DIMENSIONS=384

# LLM-based Intent Detection (thay keyword matching bằng Gemini classification)
# Đặt true để bật phân loại ý định bằng LLM, false để giữ keyword matching
LLM_INTENT_ENABLED=false

# LLM-based Reranking (Gemini đánh giá relevance score cho /v2/query endpoint)
# Đặt true để bật LLM reranking, false để giữ heuristic reranking
LLM_RERANK_ENABLED=false
